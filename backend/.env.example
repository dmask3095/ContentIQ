# ---- Server ----
NODE_ENV=development
PORT=5000
# Comma-separated list of allowed CORS origins, e.g.:
# https://your-app.vercel.app,http://localhost:3000
FRONTEND_URL=http://localhost:3000

# ---- Database ----
# Postgres connection string. For local dev: docker-compose up -d postgres
# then use postgresql://contentiq:contentiq@localhost:5432/contentiq
# In the cloud, your host (e.g. Railway) provides this value directly.
DATABASE_URL=postgresql://user:password@host:port/dbname

# ---- AI APIs ----
# Active ideation/caption provider (free tier, get a key at aistudio.google.com):
GEMINI_API_KEY=...
# Dormant until billing is set up — code path still exists, unused for now:
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GOOGLE_API_KEY=...
GOOGLE_SEARCH_ENGINE_ID=...
PERPLEXITY_API_KEY=...

# ---- Email ----
EMAIL_SERVICE=nodemailer
# nodemailer or sendgrid
SENDGRID_API_KEY=...
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=app-password

# ---- Slack ----
SLACK_BOT_TOKEN=xoxb-...
SLACK_SIGNING_SECRET=...
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# ---- Research Engine ----
RESEARCH_SWEEP_TIME=08:00
RESEARCH_SWEEP_TIMEZONE=America/Los_Angeles

# ---- Logging & Monitoring ----
LOG_LEVEL=info
SENTRY_DSN=
